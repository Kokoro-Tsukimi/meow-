# ==========================================
# 基础设施配置 (Redis)
# ==========================================
# Redis服务连接地址
REDIS_HOST=localhost
# Redis服务端口
REDIS_PORT=6379

# ==========================================
# 数据库配置 (MySQL)
# ==========================================
# MySQL服务连接地址
MYSQL_HOST=localhost
# MySQL服务端口
MYSQL_PORT=3306
# MySQL使用的数据库名
MYSQL_DATABASE=meow_gateway
# MySQL访问的用户名
MYSQL_USER=meow_user
# MySQL访问用户的密码
MYSQL_PASSWORD=请填写你的密码
# MySQL的Root超级管理员密码
MYSQL_ROOT_PASSWORD=请填写Root密码

# ==========================================
# 数据库配置 (ClickHouse)
# ==========================================
# ClickHouse服务连接地址
CLICKHOUSE_HOST=localhost
# ClickHouse服务HTTP通信端口
CLICKHOUSE_PORT=8123

# ==========================================
# 网关应用核心配置
# ==========================================
# 网关对外暴露的服务端口
GATEWAY_PORT=3000
# 用户前台端口 (frontend-user, 未配置默认 5173)
USER_PORT=5173
# 店长后台端口 (frontend-admin, 未配置默认 5174)
ADMIN_PORT=5174
# 用于用户认证签发和解析 JWT 的密钥
JWT_SECRET=请填写一个随机长字符串
# 用于超级管理员认证的专属 JWT 密钥
ADMIN_JWT_SECRET=请填写超管专用JWT密钥

# ==========================================
# 上游 API 配置
# ==========================================
# 默认转发请求的上游基础 URL (示例配置)
UPSTREAM_DEFAULT_BASE_URL=https://api.openai.com
# 上游 API 默认访问密钥
UPSTREAM_DEFAULT_API_KEY=sk-your-upstream-api-key
